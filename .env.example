# localhost is rewritten automatically in dev (simulator/emulator/physical device).
# Override with your LAN IP only if auto-detection fails, e.g. http://192.168.1.8:3001/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1
EXPO_PUBLIC_SOCKET_URL=http://localhost:3001
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Google Maps — map tiles + reverse geocoding fallback for delivery address
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
